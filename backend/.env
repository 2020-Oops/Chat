# Database — SQLite by default. Switch to PostgreSQL by changing the URL below.
DATABASE_URL=sqlite+aiosqlite:///./chat.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chatdb

# JWT settings
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
